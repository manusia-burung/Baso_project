<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#F8F9FA">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Detail Transaksi"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#154B4F"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tvRingkasanPesanan"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ringkasan Pesanan akan muncul di sini"
        android:textSize="16sp"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Metode Pembayaran"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <RadioGroup
        android:id="@+id/rgMetodePembayaran"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp">
        <RadioButton
            android:id="@+id/rbTunai"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tunai (Cash)"
            android:checked="true"/>
        <RadioButton
            android:id="@+id/rbQris"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="QRIS / E-Wallet"/>
    </RadioGroup>

    <Button
        android:id="@+id/btnProsesBayar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Proses Pembayaran"
        android:backgroundTint="#FF7F3F"
        android:textSize="16sp"
        android:textStyle="bold"/>

</LinearLayout>